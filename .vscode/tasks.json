{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/Intune.Commander.sln",
        "--no-restore"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build-release",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/Intune.Commander.DesktopReact/Intune.Commander.DesktopReact.csproj",
        "--configuration",
        "Release"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "restore",
      "command": "dotnet",
      "type": "process",
      "args": [
        "restore",
        "${workspaceFolder}/src/Intune.Commander.DesktopReact/Intune.Commander.DesktopReact.csproj"
      ],
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "build-solution",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/Intune.Commander.sln",
        "--no-restore"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "restore-solution",
      "command": "dotnet",
      "type": "process",
      "args": [
        "restore",
        "${workspaceFolder}/Intune.Commander.sln"
      ],
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "test",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        "${workspaceFolder}/Intune.Commander.sln",
        "--filter",
        "Category!=Integration"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "test-with-coverage",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        "${workspaceFolder}/Intune.Commander.sln",
        "/p:CollectCoverage=true",
        "/p:Threshold=40",
        "/p:ThresholdType=line",
        "/p:ThresholdStat=total",
        "--filter",
        "Category!=Integration"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "clean",
      "command": "dotnet",
      "type": "process",
      "args": [
        "clean",
        "${workspaceFolder}/Intune.Commander.sln"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "build-desktop-react",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/Intune.Commander.DesktopReact/Intune.Commander.DesktopReact.csproj"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "dotnet-dev"
      }
    },
    {
      "label": "npm-ci",
      "type": "process",
      "command": "npm",
      "args": [
        "ci"
      ],
      "options": {
        "cwd": "${workspaceFolder}/intune-commander-react"
      },
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "run-desktop-react",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/Intune.Commander.DesktopReact/Intune.Commander.DesktopReact.csproj"
      ],
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "app-dev"
      }
    },
    {
      "label": "run-desktop-avalonia",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/Intune.Commander.Desktop/Intune.Commander.Desktop.csproj"
      ],
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "app-dev"
      }
    },
    {
      "label": "react-dev-server",
      "type": "process",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/intune-commander-react"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".+"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+https?://localhost:\\d+/"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "app-dev"
      }
    },
    {
      "label": "dev-react-host",
      "dependsOrder": "sequence",
      "dependsOn": [
        "prepare-react-host-debug",
        "run-desktop-react"
      ],
      "problemMatcher": []
    },
    {
      "label": "prepare-react-host-debug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build-desktop-react",
        "react-dev-server"
      ],
      "problemMatcher": []
    }
  ]
}
