<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
                 xmlns:views="using:Intune.Commander.Desktop.Views"
                 xmlns:conv="using:Intune.Commander.Desktop.Converters"
                 xmlns:models="using:Intune.Commander.Desktop.Models"
                 xmlns:suki="https://github.com/kikipoulet/SukiUI"
                 xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
                 xmlns:icons="clr-namespace:Material.Icons;assembly=Material.Icons"
                 xmlns:controls="using:Intune.Commander.Desktop.Views.Controls"
                 xmlns:details="using:Intune.Commander.Desktop.Views.Controls.Details"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="1050"
                 x:Class="Intune.Commander.Desktop.Views.MainWindow"
                 x:Name="MainWin"
                 x:DataType="vm:MainWindowViewModel"
                 Title="{Binding WindowTitle}"
                 FontSize="{StaticResource FontSizeBody}"
                 Width="1200" Height="800"
                 MinWidth="1024" MinHeight="768"
                 WindowStartupLocation="CenterScreen"
                 >

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" IsVisible="{Binding IsConnected}">
            <MenuItem Header="File">
                <MenuItem Header="Refresh" Command="{Binding RefreshCommand}" InputGesture="F5" />
                <Separator />
                <MenuItem Header="Disconnect" Command="{Binding DisconnectCommand}" />
            </MenuItem>
            <MenuItem Header="Reports">
                <MenuItem Header="Assignment Report..." x:Name="MenuAssignmentReport" Click="OnAssignmentReportClick" IsEnabled="{Binding IsConnected}" />
            </MenuItem>
            <MenuItem Header="Options">
                <MenuItem Header="Resolve GUIDs in CA Exports"
                          ToggleType="CheckBox"
                          IsChecked="{Binding ResolveGuidsInCaExport}" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="Check for Updates..." x:Name="MenuCheckUpdates" Click="OnCheckForUpdatesClick" />
                <Separator />
                <MenuItem Header="Permissions..." x:Name="MenuPermissions" Click="OnPermissionsButtonClick" IsEnabled="{Binding IsConnected}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="Key" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="About Intune Commander" x:Name="MenuAbout" Click="OnAboutClick" />
            </MenuItem>

        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="8,6" MinHeight="36" IsVisible="{Binding IsConnected}">
            <DockPanel>
                <!-- Right side: Debug Log link + progress bar -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}"
                                 Width="200" Height="12"
                                 Foreground="{DynamicResource ProgressBarForegroundBrush}" Background="{DynamicResource ProgressBarBackgroundBrush}"
                                 VerticalAlignment="Center"
                                 CornerRadius="{StaticResource RadiusMedium}">
                    </ProgressBar>
                    <Border Background="Transparent" Cursor="Hand" Padding="4,2"
                            PointerPressed="OnDebugLogLinkPressed">
                        <TextBlock Text="Debug Log" FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource SystemAccentColor}"
                                   TextDecorations="Underline"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <!-- Left side: Status text + error text -->
                <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText}" FontSize="{StaticResource FontSizeBody}" />
                    <TextBlock Text="{Binding CacheStatusText}" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                    <SelectableTextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource AppErrorTextBrush}" FontSize="11"
                                         TextWrapping="Wrap"
                                         IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource AppErrorTextBrush}" FontSize="{StaticResource FontSizeCaption}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Panel>
            <!-- Login View (shown when not connected) -->
            <ContentControl Content="{Binding LoginViewModel}"
                            IsVisible="{Binding !IsConnected}">
                <ContentControl.ContentTemplate>
                    <DataTemplate DataType="vm:LoginViewModel">
                        <views:LoginView />
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>

            <!-- Connected Content (shown when connected) -->
            <DockPanel IsVisible="{Binding IsConnected}">
                <!-- Toolbar -->
                <controls:MainToolbarControl DockPanel.Dock="Top" />

                <!-- Body: custom sidebar + content -->
                <Grid ColumnDefinitions="220,*">

                    <!-- Sidebar -->
                    <controls:NavSidebarControl Grid.Column="0" />

                    <!-- Content area: top/bottom split with draggable splitter -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="3*" MinHeight="150" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="2*" MinHeight="0" />
                        </Grid.RowDefinitions>

                        <!-- Item List (top) -->
                        <controls:ItemListPanelControl Grid.Row="0"
                                                       IsVisible="{Binding !IsOverviewCategory}" />

                        <!-- Overview Dashboard (spans all rows when visible) -->
                        <views:OverviewView Grid.Row="0" Grid.RowSpan="3"
                                            DataContext="{Binding Overview}"
                                            IsVisible="{Binding $parent[suki:SukiWindow].((vm:MainWindowViewModel)DataContext).IsOverviewCategory}" />

                        <!-- Draggable splitter between list and detail -->
                        <GridSplitter Grid.Row="1"
                                      Height="6"
                                      ResizeDirection="Rows"
                                      HorizontalAlignment="Stretch"
                                      Background="Transparent"
                                      Cursor="SizeNorthSouth">
                            <GridSplitter.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!IsOverviewCategory" />
                                    <Binding Path="IsDetailPaneVisible" />
                                </MultiBinding>
                            </GridSplitter.IsVisible>
                        </GridSplitter>

                        <!-- Detail Pane (bottom) -->
                        <DockPanel Grid.Row="2" Margin="8,4,8,8">
                            <DockPanel.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!IsOverviewCategory" />
                                    <Binding Path="IsDetailPaneVisible" />
                                </MultiBinding>
                            </DockPanel.IsVisible>
                            <controls:DetailPaneHeaderControl DockPanel.Dock="Top" />

                            <!-- All detail panels share the same fill area; IsVisible picks the active one -->
                            <Panel>

                            <!-- No selection placeholder -->
                            <TextBlock Text="Select an item to view details"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" FontSize="{StaticResource FontSizeSubheading}"
                                       x:Name="PlaceholderNoSelection">
                                <TextBlock.IsVisible>
                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                        <Binding Path="SelectedConfiguration" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedCompliancePolicy" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedSettingsCatalogPolicy" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedApplication" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedEndpointSecurityIntent" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAdministrativeTemplate" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedEnrollmentConfiguration" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAppProtectionPolicy" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedManagedDeviceAppConfiguration" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedTargetedManagedAppConfiguration" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedTermsAndConditions" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedScopeTag" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedRoleDefinition" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedIntuneBrandingProfile" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAzureBrandingLocalization" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAutopilotProfile" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedDeviceHealthScript" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedMacCustomAttribute" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedFeatureUpdateProfile" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedNamedLocation" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAuthenticationStrengthPolicy" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAuthenticationContextClassReference" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedTermsOfUseAgreement" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedConditionalAccessPolicy" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAssignmentFilter" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedPolicySet" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAppAssignmentRow" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedDynamicGroupRow" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAssignedGroupRow" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedDeviceManagementScript" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedDeviceShellScript" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedComplianceScript" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAdmxFile" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedReusablePolicySetting" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedNotificationTemplate" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedQualityUpdateProfile" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedDriverUpdateProfile" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedAppleDepSetting" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedDeviceCategory" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedVppToken" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedCloudPcProvisioningPolicy" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedCloudPcUserSetting" Converter="{x:Static ObjectConverters.IsNull}" />
                                        <Binding Path="SelectedRoleAssignment" Converter="{x:Static ObjectConverters.IsNull}" />
                                    </MultiBinding>
                                </TextBlock.IsVisible>
                            </TextBlock>

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Device Configuration details               -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:DeviceConfigurationDetailPanel IsVisible="{Binding SelectedConfiguration, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Compliance Policy details                  -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:CompliancePolicyDetailPanel IsVisible="{Binding SelectedCompliancePolicy, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Settings Catalog details                   -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:SettingsCatalogDetailPanel IsVisible="{Binding SelectedSettingsCatalogPolicy, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Conditional Access details                 -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:ConditionalAccessDetailPanel IsVisible="{Binding SelectedConditionalAccessPolicy, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Assignment Filter details                  -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:AssignmentFilterDetailPanel IsVisible="{Binding SelectedAssignmentFilter, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Policy Set details                         -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:PolicySetDetailPanel IsVisible="{Binding SelectedPolicySet, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Application details                        -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:ApplicationDetailPanel IsVisible="{Binding SelectedApplication, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Endpoint Security details                  -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:EndpointSecurityDetailPanel IsVisible="{Binding SelectedEndpointSecurityIntent, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Administrative Template details            -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:AdministrativeTemplateDetailPanel IsVisible="{Binding SelectedAdministrativeTemplate, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Enrollment Configuration details           -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:EnrollmentConfigurationDetailPanel IsVisible="{Binding SelectedEnrollmentConfiguration, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- App Protection Policy details              -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:AppProtectionPolicyDetailPanel IsVisible="{Binding SelectedAppProtectionPolicy, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Managed Device App Configuration details   -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:ManagedDeviceAppConfigDetailPanel IsVisible="{Binding SelectedManagedDeviceAppConfiguration, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Targeted Managed App Configuration details -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:TargetedManagedAppConfigDetailPanel IsVisible="{Binding SelectedTargetedManagedAppConfiguration, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Terms and Conditions details               -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:TermsAndConditionsDetailPanel IsVisible="{Binding SelectedTermsAndConditions, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Scope Tag details                          -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:ScopeTagDetailPanel IsVisible="{Binding SelectedScopeTag, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Role Definition details                    -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:RoleDefinitionDetailPanel IsVisible="{Binding SelectedRoleDefinition, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Intune Branding details                    -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:IntuneBrandingDetailPanel IsVisible="{Binding SelectedIntuneBrandingProfile, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Azure Branding details                     -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:AzureBrandingDetailPanel IsVisible="{Binding SelectedAzureBrandingLocalization, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Autopilot Profile details                  -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:AutopilotProfileDetailPanel IsVisible="{Binding SelectedAutopilotProfile, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Device Health Script details               -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:DeviceHealthScriptDetailPanel IsVisible="{Binding SelectedDeviceHealthScript, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Mac Custom Attribute details               -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:MacCustomAttributeDetailPanel IsVisible="{Binding SelectedMacCustomAttribute, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Feature Update Profile details             -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:FeatureUpdateProfileDetailPanel IsVisible="{Binding SelectedFeatureUpdateProfile, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Named Location details                     -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:NamedLocationDetailPanel IsVisible="{Binding SelectedNamedLocation, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Authentication Strength details            -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:AuthenticationStrengthDetailPanel IsVisible="{Binding SelectedAuthenticationStrengthPolicy, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Authentication Context details             -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:AuthenticationContextDetailPanel IsVisible="{Binding SelectedAuthenticationContextClassReference, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Terms of Use details                       -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:TermsOfUseDetailPanel IsVisible="{Binding SelectedTermsOfUseAgreement, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- application assignments Row details                  -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:AppAssignmentRowDetailPanel IsVisible="{Binding SelectedAppAssignmentRow, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Dynamic Group details                      -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:DynamicGroupDetailPanel IsVisible="{Binding SelectedDynamicGroupRow, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Assigned Group details                     -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:AssignedGroupDetailPanel IsVisible="{Binding SelectedAssignedGroupRow, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Device Management Script details           -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:DeviceManagementScriptDetailPanel IsVisible="{Binding SelectedDeviceManagementScript, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Device Shell Script details                -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:DeviceShellScriptDetailPanel IsVisible="{Binding SelectedDeviceShellScript, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Compliance Script details                  -->
                            <!-- ═══════════════════════════════════════════ -->
                                                        <details:ComplianceScriptDetailPanel IsVisible="{Binding SelectedComplianceScript, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- ADMX File details                          -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:AdmxFileDetailPanel IsVisible="{Binding SelectedAdmxFile, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Reusable Policy Setting details            -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:ReusablePolicySettingDetailPanel IsVisible="{Binding SelectedReusablePolicySetting, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Notification Template details              -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:NotificationTemplateDetailPanel IsVisible="{Binding SelectedNotificationTemplate, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Quality Update Profile details             -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:QualityUpdateProfileDetailPanel IsVisible="{Binding SelectedQualityUpdateProfile, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Driver Update Profile details              -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:DriverUpdateProfileDetailPanel IsVisible="{Binding SelectedDriverUpdateProfile, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Apple DEP Setting details                  -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:AppleDepSettingDetailPanel IsVisible="{Binding SelectedAppleDepSetting, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Device Category details                    -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:DeviceCategoryDetailPanel IsVisible="{Binding SelectedDeviceCategory, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- VPP Token details                          -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:VppTokenDetailPanel IsVisible="{Binding SelectedVppToken, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Cloud PC Provisioning Policy details       -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:CloudPcProvisioningPolicyDetailPanel IsVisible="{Binding SelectedCloudPcProvisioningPolicy, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Cloud PC User Setting details              -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:CloudPcUserSettingDetailPanel IsVisible="{Binding SelectedCloudPcUserSetting, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            <!-- ═══════════════════════════════════════════ -->
                            <!-- Role Assignment details                    -->
                            <!-- ═══════════════════════════════════════════ -->
                            <details:RoleAssignmentDetailPanel IsVisible="{Binding SelectedRoleAssignment, Converter={x:Static ObjectConverters.IsNotNull}}" />

                            </Panel>

                        </DockPanel>
                    </Grid>
                </Grid>
            </DockPanel>

            <!-- Version info (always visible, overlaid in bottom-left) -->
            <TextBlock Text="{Binding VersionText}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Opacity="0.4"
                       Margin="8,0,0,4"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Bottom"
                       IsHitTestVisible="False" />

        </Panel>
    </DockPanel>
</suki:SukiWindow>
