<suki:SukiWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
        xmlns:m="using:Microsoft.Graph.Beta.Models"
        xmlns:models="using:Intune.Commander.Core.Models"
        xmlns:graphModels="using:Microsoft.Graph.Beta.Models"
        xmlns:suki="https://github.com/kikipoulet/SukiUI"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="Intune.Commander.Desktop.Views.OnDemandDeployWindow"
        x:DataType="vm:OnDemandDeployViewModel"
        Title="{Binding ScriptName, StringFormat='Deploy: {0}'}"
        Width="1600" Height="900"
        MinWidth="1100" MinHeight="500"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="24">

        <!-- Top: Search bar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12"
                   IsVisible="{Binding !DeploymentComplete}">
            <Button DockPanel.Dock="Right" Content="Search"
                    Command="{Binding SearchDevicesCommand}"
                    IsEnabled="{Binding !IsSearching}"
                    Margin="8,0,0,0"
                    Classes="Large"
                    HorizontalContentAlignment="Center" />
            <TextBox Text="{Binding SearchQuery}"
                     Watermark="Search devices by name..."
                     KeyDown="OnSearchKeyDown"
                     FontSize="{StaticResource FontSizeSubheading}" Padding="8" />
        </DockPanel>

        <!-- Top: Deployment Complete Banner (shown after deploy) -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding DeploymentComplete}"
                CornerRadius="8" Padding="16" Margin="0,0,0,12"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <Button Content="Stop Monitoring"
                            Command="{Binding StopMonitoringCommand}"
                            IsVisible="{Binding IsMonitoring}"
                            Classes="Flat" />
                    <Button Content="Refresh Now"
                            Command="{Binding StartMonitoringCommand}"
                            IsVisible="{Binding !IsMonitoring}"
                            Classes="Flat Accent" />
                </StackPanel>
                <StackPanel Spacing="6">
                    <TextBlock Text="Deployment Complete" FontSize="22" FontWeight="Bold" />
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding SucceededCount}" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBadgeBrush}" FontSize="20" />
                            <TextBlock Text="succeeded" VerticalAlignment="Center"
                                       FontSize="15" Opacity="0.7" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6"
                                    IsVisible="{Binding FailedCount}">
                            <TextBlock Text="{Binding FailedCount}" FontWeight="Bold"
                                       Foreground="{DynamicResource ErrorBadgeBrush}" FontSize="20" />
                            <TextBlock Text="failed" VerticalAlignment="Center"
                                       FontSize="15" Opacity="0.7" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding MonitoringStatusText}"
                               FontSize="13" Opacity="0.6" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Bottom: Status + Deploy + Close -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                <Button Content="{Binding TargetDevices.Count, StringFormat='Deploy to {0} device(s)'}"
                        Command="{Binding DeployToAllCommand}"
                        IsEnabled="{Binding CanDeploy}"
                        IsVisible="{Binding !DeploymentComplete}"
                        Classes="Flat Accent Large" />
                <Button Content="Close" Click="OnCloseClick" Classes="Large" />
            </StackPanel>
            <StackPanel Orientation="Vertical" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusText}" FontSize="{StaticResource FontSizeBody}" Opacity="0.7" />
                <ProgressBar Value="{Binding DeployProgress}" Maximum="100"
                             IsVisible="{Binding IsDeploying}"
                             Height="8" CornerRadius="4"
                             Foreground="{DynamicResource ProgressBarForegroundBrush}"
                             Background="{DynamicResource ProgressBarBackgroundBrush}" />
                <TextBlock Text="{Binding DeployProgressText}"
                           IsVisible="{Binding IsDeploying}"
                           FontSize="{StaticResource FontSizeCaption}" Opacity="0.6" />
            </StackPanel>
        </DockPanel>

        <!-- Error message -->
        <Border DockPanel.Dock="Bottom"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="{DynamicResource AppErrorBackgroundBrush}" CornerRadius="{StaticResource RadiusSmall}" Padding="8" Margin="0,4,0,0">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource AppErrorTextBrush}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
        </Border>

        <!-- ====== PRE-DEPLOY: Search + Target panels ====== -->
        <Grid ColumnDefinitions="*,16,*" Margin="0,0,0,4"
              IsVisible="{Binding !DeploymentComplete}">

            <!-- Left: Search Results -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Search Results" FontWeight="SemiBold"
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,6" />
                <DataGrid ItemsSource="{Binding SearchResults}"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Device Name" Binding="{Binding DeviceName}" Width="*" />
                        <DataGridTextColumn Header="OS" Binding="{Binding OperatingSystem}" Width="80" />
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="120" />
                        <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="100" />
                        <DataGridTextColumn Header="Last Sync" Binding="{Binding LastSyncDateTime}" Width="130" />
                        <DataGridTemplateColumn Header="" Width="56">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="m:ManagedDevice">
                                    <Button Content="+"
                                            Click="OnAddDeviceClick"
                                            Padding="8,2" Margin="0,0,10,0" FontWeight="Bold"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Right: Target Devices -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold"
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,6">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Target Devices ({0})">
                            <Binding Path="TargetDevices.Count" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <DataGrid ItemsSource="{Binding TargetDevices}"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Device Name" Binding="{Binding DeviceName}" Width="*" />
                        <DataGridTextColumn Header="OS" Binding="{Binding OperatingSystem}" Width="80" />
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="120" />
                        <DataGridTemplateColumn Header="" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="m:ManagedDevice">
                                    <Button Content="Remove"
                                            Click="OnRemoveDeviceClick"
                                            Padding="4,2" FontSize="11"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <!-- ====== POST-DEPLOY: Results + Monitoring ====== -->
        <Grid ColumnDefinitions="*,16,*" Margin="0,0,0,4"
              IsVisible="{Binding DeploymentComplete}">

            <!-- Left: Deployment Results -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Deployment Results" FontWeight="SemiBold"
                           FontSize="{StaticResource FontSizeBody}" Margin="0,0,0,6" />
                <DataGrid ItemsSource="{Binding DeploymentResults}"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Device" Binding="{Binding DeviceName}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Succeeded}" Width="80" />
                        <DataGridTextColumn Header="Dispatched" Binding="{Binding DispatchedAt}" Width="160" />
                        <DataGridTextColumn Header="Error" Binding="{Binding ErrorMessage}" Width="200" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <!-- Right: Live Monitoring -->
            <DockPanel Grid.Column="2">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <ProgressBar DockPanel.Dock="Right"
                                 IsIndeterminate="True" Width="60" Height="6"
                                 IsVisible="{Binding IsMonitoring}"
                                 CornerRadius="3" Margin="8,0,0,0"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource ProgressBarForegroundBrush}"
                                 Background="{DynamicResource ProgressBarBackgroundBrush}" />
                    <TextBlock Text="Device Run States (Live)" FontWeight="SemiBold"
                               FontSize="{StaticResource FontSizeBody}" />
                </DockPanel>
                <DataGrid ItemsSource="{Binding MonitoringStates}"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Device" Binding="{Binding ManagedDevice.DeviceName}" Width="*" />
                        <DataGridTextColumn Header="Detection" Binding="{Binding DetectionState}" Width="110" />
                        <DataGridTextColumn Header="Remediation" Binding="{Binding RemediationState}" Width="110" />
                        <DataGridTextColumn Header="Last Updated" Binding="{Binding LastStateUpdateDateTime}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</suki:SukiWindow>
