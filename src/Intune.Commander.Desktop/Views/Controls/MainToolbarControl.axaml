<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="Intune.Commander.Desktop.Views.Controls.MainToolbarControl"
             x:DataType="vm:MainWindowViewModel">
    <StackPanel>
        <Border Padding="12,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <DropDownButton Content="Actions" Classes="Small">
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                <MenuItem Header="Export Selected" Command="{Binding ExportSelectedCommand}" />
                                <MenuItem Header="Export All" Command="{Binding ExportAllCommand}" />
                                <Separator />
                                <MenuItem Header="Import..." x:Name="ImportMenuItem" />
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="4,2" />
                    <Button Command="{Binding DownloadAllToCacheCommand}"
                            IsVisible="{Binding !IsDownloadingAll}"
                            ToolTip.Tip="Downloads all Intune data types into the local cache"
                            FontWeight="SemiBold"
                            Background="{DynamicResource SuccessBadgeBrush}"
                            Foreground="White"
                            Classes="Flat Accent Small"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Download" />
                            <TextBlock Text="Download All to Cache" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelDownloadAllCommand}"
                            IsVisible="{Binding IsDownloadingAll}"
                            Classes="Flat Accent Small">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Stop" />
                            <TextBlock Text="Cancel Download" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <ComboBox ItemsSource="{Binding SwitcherProfiles}"
                              SelectedItem="{Binding SelectedSwitchProfile}"
                              MinWidth="180"
                              VerticalAlignment="Center"
                              IsEnabled="{Binding !IsBusy}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button x:Name="GroupLookupButton"
                            Content="Group Lookup"
                            Classes="Small"
                            ToolTip.Tip="Look up group memberships"
                            IsEnabled="{Binding IsConnected}" />
                    <Button Content="Disconnect" Classes="Small" Command="{Binding DisconnectCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Download All Progress -->
        <ProgressBar IsIndeterminate="False"
                     Maximum="100"
                     Value="{Binding DownloadProgressPercent}"
                     IsVisible="{Binding IsDownloadingAll}"
                     Height="4"
                     Foreground="{DynamicResource ProgressBarForegroundBrush}"
                     Background="{DynamicResource ProgressBarBackgroundBrush}"
                     CornerRadius="0" />
        <TextBlock Text="{Binding DownloadProgress}"
                   IsVisible="{Binding IsDownloadingAll}"
                   FontSize="{StaticResource FontSizeBody}"
                   HorizontalAlignment="Center"
                   Margin="0,2,0,0"
                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
    </StackPanel>
</UserControl>
