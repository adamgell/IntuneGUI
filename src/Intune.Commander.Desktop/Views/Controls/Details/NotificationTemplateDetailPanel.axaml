<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:conv="using:Intune.Commander.Desktop.Converters"
             xmlns:controls="using:Intune.Commander.Desktop.Views.Controls"
             x:Class="Intune.Commander.Desktop.Views.Controls.Details.NotificationTemplateDetailPanel"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="4">
            <TextBlock Text="Notification Template" Classes="SectionHeader" />

            <!-- Properties -->
            <Border Classes="SectionCard">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Display Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedNotificationTemplate.DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Description" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedNotificationTemplate.Description}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Default Locale" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SelectedNotificationTemplate.DefaultLocale}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Last Modified" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SelectedNotificationTemplate.LastModifiedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Branding Options" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedNotificationTemplate.BrandingOptions}" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedNotificationTemplate.Id}" FontSize="{StaticResource FontSizeCaption}" Opacity="0.8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Localized Messages -->
            <Expander Header="Localized Messages" IsExpanded="True" Margin="0,4,0,0">
                <StackPanel Spacing="4" Margin="4">
                    <TextBlock Text="No localized messages loaded"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeBody}"
                               IsVisible="{Binding !SelectedItemNotificationMessages.Count}" />
                    <ItemsControl ItemsSource="{Binding SelectedItemNotificationMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:LocalizedNotificationMessageItem">
                                <Border Classes="SectionCard" Margin="0,2">
                                    <StackPanel Spacing="4">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Locale" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                            <SelectableTextBlock Text="{Binding Locale}" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Subject" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                            <SelectableTextBlock Text="{Binding Subject}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Message" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                            <SelectableTextBlock Text="{Binding MessageTemplate}" TextWrapping="Wrap" FontSize="{StaticResource FontSizeCaption}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
