<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:conv="using:Intune.Commander.Desktop.Converters"
             xmlns:controls="using:Intune.Commander.Desktop.Views.Controls"
             x:Class="Intune.Commander.Desktop.Views.Controls.Details.DeviceHealthScriptDetailPanel"
             x:DataType="vm:MainWindowViewModel"
             MaxWidth="420">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="4">
            <TextBlock Text="Device Health Script" Classes="SectionHeader" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10" DataContext="{Binding SelectedDeviceHealthScript}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Display Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Description" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding Id}" FontSize="{StaticResource FontSizeCaption}" Opacity="0.8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Section: Script Details -->
            <TextBlock Text="Script Details" Classes="SectionHeaderSpaced" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10" DataContext="{Binding SelectedDeviceHealthScript}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Publisher" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemPublisher}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Created" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding CreatedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Last Modified" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding LastModifiedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Version" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemVersion}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Run As Account" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemRunAsAccount}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Run As 32-bit" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemRunAs32BitText}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Version" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemVersion}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Enforce Signature Check" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemEnforceSignatureCheck}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Section: Scripts -->
            <TextBlock Text="Scripts" Classes="SectionHeaderSpaced" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="4">
                    <Expander Header="Detection Script" IsExpanded="False">
                        <Border Padding="4" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" CornerRadius="4">
                            <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemDetectionScript}"
                                                 FontFamily="Consolas,Courier New,monospace" FontSize="{StaticResource FontSizeCaption}" TextWrapping="Wrap" />
                        </Border>
                    </Expander>
                    <Expander Header="Remediation Script" IsExpanded="False">
                        <Border Padding="4" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" CornerRadius="4">
                            <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemRemediationScript}"
                                                 FontFamily="Consolas,Courier New,monospace" FontSize="{StaticResource FontSizeCaption}" TextWrapping="Wrap" />
                        </Border>
                    </Expander>
                </StackPanel>
            </Border>

            <!-- Section: Run Summary -->
            <TextBlock Text="Run Summary" Classes="SectionHeaderSpaced" />
            <Border Classes="SectionCard">
                <Panel>
                    <!-- Loading spinner -->
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding IsLoadingRunSummary}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="0,8">
                        <ProgressBar IsIndeterminate="True" Width="120" Height="8"
                                     Foreground="{DynamicResource ProgressBarForegroundBrush}"
                                     Background="{DynamicResource ProgressBarBackgroundBrush}"
                                     CornerRadius="4" />
                        <TextBlock Text="Loading..." FontSize="{StaticResource FontSizeCaption}" Opacity="0.7" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Summary counts -->
                    <StackPanel IsVisible="{Binding !IsLoadingRunSummary}">
                        <Grid ColumnDefinitions="*,*,*,*" Margin="0,4"
                              IsVisible="{Binding SelectedScriptRunSummary, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="2">
                                <TextBlock Text="No Issues" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedScriptRunSummary.NoIssueDetectedDeviceCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SuccessBadgeBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="2">
                                <TextBlock Text="Detected" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedScriptRunSummary.IssueDetectedDeviceCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource WarningBadgeBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="2">
                                <TextBlock Text="Remediated" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedScriptRunSummary.IssueRemediatedDeviceCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource InfoBadgeBrush}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center" Spacing="2">
                                <TextBlock Text="Errors" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedScriptRunSummary.IssueReoccurredDeviceCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource ErrorBadgeBrush}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="No run summary available"
                                   IsVisible="{Binding SelectedScriptRunSummary, Converter={x:Static ObjectConverters.IsNull}}"
                                   FontSize="{StaticResource FontSizeBody}" Opacity="0.5"
                                   HorizontalAlignment="Center" Margin="0,8" />
                    </StackPanel>
                </Panel>
            </Border>

            <!-- Deploy On-Demand button -->
            <Button Content="Deploy On-Demand"
                    Command="{Binding OpenOnDemandDeployCommand}"
                    HorizontalAlignment="Right"
                    Margin="0,4,0,0"
                    Classes="Medium Accent" />

            <!-- Section: Device Run States -->
            <TextBlock Text="Device Run States" Classes="SectionHeaderSpaced" />
            <Border Classes="SectionCard">
                <Panel>
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding IsLoadingRunSummary}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="0,8">
                        <ProgressBar IsIndeterminate="True" Width="120" Height="8"
                                     Foreground="{DynamicResource ProgressBarForegroundBrush}"
                                     Background="{DynamicResource ProgressBarBackgroundBrush}"
                                     CornerRadius="4" />
                        <TextBlock Text="Loading..." FontSize="{StaticResource FontSizeCaption}" Opacity="0.7" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel IsVisible="{Binding !IsLoadingRunSummary}">
                        <DataGrid ItemsSource="{Binding SelectedScriptDeviceRunStates}"
                                  IsVisible="{Binding SelectedScriptDeviceRunStates.Count}"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  CanUserResizeColumns="True"
                                  MaxHeight="300"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Device"
                                                    Binding="{Binding ManagedDevice.DeviceName}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Detection"
                                                    Binding="{Binding DetectionState}"
                                                    Width="90" />
                                <DataGridTextColumn Header="Remediation"
                                                    Binding="{Binding RemediationState}"
                                                    Width="95" />
                                <DataGridTextColumn Header="Last Updated"
                                                    Binding="{Binding LastStateUpdateDateTime}"
                                                    Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="No device run states available"
                                   IsVisible="{Binding !SelectedScriptDeviceRunStates.Count}"
                                   FontSize="{StaticResource FontSizeBody}" Opacity="0.5"
                                   HorizontalAlignment="Center" Margin="0,8" />
                    </StackPanel>
                </Panel>
            </Border>

            <!-- Section: Assignments -->
            <controls:AssignmentListControl Assignments="{Binding SelectedItemAssignments}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
