<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:conv="using:Intune.Commander.Desktop.Converters"
             xmlns:controls="using:Intune.Commander.Desktop.Views.Controls"
             x:Class="Intune.Commander.Desktop.Views.Controls.Details.AppleDepSettingDetailPanel"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="4">
            <TextBlock Text="Apple DEP Setting" Classes="SectionHeader" />

            <!-- Properties -->
            <Border Classes="SectionCard">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Token Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedAppleDepSetting.TokenName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Apple ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedAppleDepSetting.AppleIdentifier}" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedAppleDepSetting.Id}" FontSize="{StaticResource FontSizeCaption}" Opacity="0.8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Token Details -->
            <TextBlock Text="Token Details" Classes="SectionHeaderSpaced" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Token Type" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SelectedAppleDepSetting.TokenType}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Token Expiry" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SelectedAppleDepSetting.TokenExpirationDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Synced Device Count" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SelectedAppleDepSetting.SyncedDeviceCount}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Data Sharing Consent" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SelectedAppleDepSetting.DataSharingConsentGranted}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Enrollment Details -->
            <TextBlock Text="Enrollment Details" Classes="SectionHeaderSpaced" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Last Sync" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SelectedAppleDepSetting.LastSuccessfulSyncDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Last Modified" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SelectedAppleDepSetting.LastModifiedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
