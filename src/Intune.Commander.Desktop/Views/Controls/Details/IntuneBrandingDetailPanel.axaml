<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:conv="using:Intune.Commander.Desktop.Converters"
             x:Class="Intune.Commander.Desktop.Views.Controls.Details.IntuneBrandingDetailPanel"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="4">
            <TextBlock Text="Intune Branding Profile" Classes="SectionHeader" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10" DataContext="{Binding SelectedIntuneBrandingProfile}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Display Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Profile Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding ProfileName}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Profile Description" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding ProfileDescription}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Is Default Profile" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding IsDefaultProfile}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Show Logo" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding ShowLogo}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="2">
                        <TextBlock Text="ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding Id}" FontSize="{StaticResource FontSizeCaption}" Opacity="0.8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Metadata" Classes="SectionHeader" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10" DataContext="{Binding SelectedIntuneBrandingProfile}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="OData Type" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding OdataType}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Section: Timestamps -->
            <TextBlock Text="Timestamps" Classes="SectionHeaderSpaced" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10" DataContext="{Binding SelectedIntuneBrandingProfile}">
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Created" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding CreatedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Last Modified" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding LastModifiedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Section: Contact IT -->
            <TextBlock Text="Contact IT" Classes="SectionHeaderSpaced" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10" DataContext="{Binding SelectedIntuneBrandingProfile}">
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Contact Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding ContactITName}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Email Address" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding ContactITEmailAddress}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Phone Number" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding ContactITPhoneNumber}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Support Site" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding OnlineSupportSiteName}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="2">
                        <TextBlock Text="IT Contact Notes" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding ContactITNotes}" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
