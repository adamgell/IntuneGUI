<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:conv="using:Intune.Commander.Desktop.Converters"
             xmlns:controls="using:Intune.Commander.Desktop.Views.Controls"
             x:Class="Intune.Commander.Desktop.Views.Controls.Details.QualityUpdateProfileDetailPanel"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="4">
            <TextBlock Text="Quality Update Profile" Classes="SectionHeader" />

            <!-- Properties -->
            <Border Classes="SectionCard">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Display Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedQualityUpdateProfile.DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Description" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedQualityUpdateProfile.Description}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Deployable Content" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedQualityUpdateProfile.DeployableContentDisplayName}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Created" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SelectedQualityUpdateProfile.CreatedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Last Modified" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SelectedQualityUpdateProfile.LastModifiedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="2">
                        <TextBlock Text="ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedQualityUpdateProfile.Id}" FontSize="{StaticResource FontSizeCaption}" Opacity="0.8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Assignments -->
            <controls:AssignmentListControl Assignments="{Binding SelectedItemAssignments}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
