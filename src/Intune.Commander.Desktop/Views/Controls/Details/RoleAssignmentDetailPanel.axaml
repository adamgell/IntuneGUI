<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:conv="using:Intune.Commander.Desktop.Converters"
             x:Class="Intune.Commander.Desktop.Views.Controls.Details.RoleAssignmentDetailPanel"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="4">
            <TextBlock Text="Role Assignment" Classes="SectionHeader" />

            <!-- Properties -->
            <Border Classes="SectionCard">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Display Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedRoleAssignment.DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Description" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedRoleAssignment.Description}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Scope Type" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedRoleAssignment.ScopeType}" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedRoleAssignment.Id}" FontSize="{StaticResource FontSizeCaption}" Opacity="0.8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Scope Members -->
            <Expander Header="Resource Scopes" IsExpanded="True" Margin="0,4,0,0">
                <StackPanel Spacing="4" Margin="4">
                    <TextBlock Text="No resource scopes"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeBody}"
                               IsVisible="{Binding !SelectedRoleAssignment.ResourceScopes.Count}" />
                    <ItemsControl ItemsSource="{Binding SelectedRoleAssignment.ResourceScopes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Padding="6,3" Margin="0,1">
                                    <SelectableTextBlock Text="{Binding}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

            <TextBlock Text="Scope Members" Classes="SectionHeaderSpaced" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="4">
                    <TextBlock Text="No scope members"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                               FontSize="{StaticResource FontSizeBody}"
                               IsVisible="{Binding !SelectedRoleAssignment.ScopeMembers.Count}" />
                    <ItemsControl ItemsSource="{Binding SelectedRoleAssignment.ScopeMembers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <SelectableTextBlock Text="{Binding}" FontSize="{StaticResource FontSizeBody}" Margin="0,1,0,1" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
