<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:conv="using:Intune.Commander.Desktop.Converters"
             x:Class="Intune.Commander.Desktop.Views.Controls.Details.AssignedGroupDetailPanel"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="4" DataContext="{Binding SelectedAssignedGroupRow}">

            <TextBlock Text="Group Properties" Classes="SectionHeader" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Group Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding GroupName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Description" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Group Type" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding GroupType}" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Group ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding GroupId}" FontSize="{StaticResource FontSizeCaption}" Opacity="0.8" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Security Enabled" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding SecurityEnabled}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Mail Enabled" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding MailEnabled}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Created Date" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding CreatedDate, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Membership" Classes="SectionHeader" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,*,*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Total" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding TotalMembers}" FontSize="{StaticResource FontSizeSubheading}" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Users" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding Users}" FontSize="{StaticResource FontSizeSubheading}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock Text="Devices" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding Devices}" FontSize="{StaticResource FontSizeSubheading}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="2">
                            <TextBlock Text="Nested" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding NestedGroups}" FontSize="{StaticResource FontSizeSubheading}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Section: Members List -->
            <TextBlock Text="Members" Classes="SectionHeader" />
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).IsLoadingGroupMembers}"
                         Height="2" Margin="0,0,0,4" />
            <Border Classes="SectionCard">
                <StackPanel>
                    <TextBlock Text="No members"
                               Foreground="{DynamicResource AppTextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"
                               IsVisible="{Binding !$parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedGroupMembers.Count}" />
                    <ItemsControl ItemsSource="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedGroupMembers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,3" Margin="0,0,0,4">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left"
                                                Background="{DynamicResource SystemAccentColor}"
                                                CornerRadius="2" Padding="5,1" Margin="0,2,6,0"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding MemberType}"
                                                       FontSize="{StaticResource FontSizeCaption}" Foreground="White" />
                                        </Border>
                                        <TextBlock DockPanel.Dock="Right"
                                                   Text="{Binding Status}"
                                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        <StackPanel Spacing="1">
                                            <SelectableTextBlock Text="{Binding DisplayName}"
                                                                 FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
                                            <SelectableTextBlock Text="{Binding SecondaryInfo}"
                                                                 FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" Opacity="0.8"
                                                                 IsVisible="{Binding SecondaryInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            <SelectableTextBlock Text="{Binding TertiaryInfo}"
                                                                 FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" Opacity="0.6"
                                                                 IsVisible="{Binding TertiaryInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
