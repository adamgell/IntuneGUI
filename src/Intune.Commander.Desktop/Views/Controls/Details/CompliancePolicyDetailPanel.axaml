<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:conv="using:Intune.Commander.Desktop.Converters"
             xmlns:controls="using:Intune.Commander.Desktop.Views.Controls"
             xmlns:models="using:Intune.Commander.Desktop.Models"
             x:Class="Intune.Commander.Desktop.Views.Controls.Details.CompliancePolicyDetailPanel"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="4">

            <!-- Section: Properties -->
            <TextBlock Text="Properties" Classes="SectionHeader" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10" DataContext="{Binding SelectedCompliancePolicy}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Description" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Platform / Type" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemTypeName}"
                                             TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding Id}" FontSize="{StaticResource FontSizeCaption}" Opacity="0.8" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Created" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding CreatedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Last Modified" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding LastModifiedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Version" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding Version}" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                    <StackPanel Spacing="2"
                                IsVisible="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemRoleScopeTags.Count}">
                        <TextBlock Text="Role Scope Tags" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemRoleScopeTags, Converter={x:Static conv:StringListConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Section: SETTINGS -->
            <TextBlock Text="SETTINGS" Classes="SectionHeader" />
            <Border Classes="SectionCard">
                <StackPanel>
                    <TextBlock Text="No settings"
                               Foreground="{DynamicResource AppTextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"
                               IsVisible="{Binding !SelectedItemComplianceSettings.Count}" />
                    <ItemsControl ItemsSource="{Binding SelectedItemComplianceSettings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:SettingItem">
                                <Border BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                        BorderThickness="0,0,0,1" Padding="4,6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                   TextWrapping="Wrap" VerticalAlignment="Center" />
                                        <SelectableTextBlock Grid.Column="1" Text="{Binding Value}" FontSize="{StaticResource FontSizeBody}"
                                                             FontWeight="SemiBold" HorizontalAlignment="Right"
                                                             VerticalAlignment="Center"
                                                             Margin="16,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Section: ACTIONS -->
            <TextBlock Text="ACTIONS" Classes="SectionHeader" />
            <Border Classes="SectionCard">
                <StackPanel>
                    <TextBlock Text="No actions configured"
                               Foreground="{DynamicResource AppTextSecondaryBrush}" FontSize="{StaticResource FontSizeBody}"
                               IsVisible="{Binding !SelectedItemNonComplianceActions.Count}" />
                    <ItemsControl ItemsSource="{Binding SelectedItemNonComplianceActions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:NonComplianceActionItem">
                                <Border BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                        BorderThickness="0,0,0,1" Padding="4,6">
                                    <StackPanel Spacing="4">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding ActionTypeDisplay}"
                                                       FontSize="{StaticResource FontSizeBody}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding GracePeriodDisplay}"
                                                       FontSize="{StaticResource FontSizeBody}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                       HorizontalAlignment="Right" />
                                        </Grid>
                                        <TextBlock Text="Notification template configured"
                                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                   IsVisible="{Binding HasNotificationTemplate}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Section: Assignments -->
            <controls:AssignmentListControl Assignments="{Binding SelectedItemAssignments}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
