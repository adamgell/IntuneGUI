<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:conv="using:Intune.Commander.Desktop.Converters"
             xmlns:controls="using:Intune.Commander.Desktop.Views.Controls"
             x:Class="Intune.Commander.Desktop.Views.Controls.Details.EndpointSecurityDetailPanel"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="4">
            <TextBlock Text="Policy Information" Classes="SectionHeader" />
            <Border Classes="SectionCard">
                <StackPanel Spacing="10" DataContext="{Binding SelectedEndpointSecurityIntent}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                        <TextBlock Text="Description" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding Description}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Is Assigned" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding IsAssigned}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Last Modified" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding LastModifiedDateTime, Converter={x:Static conv:HumanDateTimeConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Template ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding TemplateId}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Migrating to Config Policy" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                            <SelectableTextBlock Text="{Binding IsMigratingToConfigurationPolicy}" FontSize="{StaticResource FontSizeBody}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="2">
                        <TextBlock Text="ID" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding Id}" FontSize="{StaticResource FontSizeCaption}" Opacity="0.8" />
                    </StackPanel>
                    <StackPanel Spacing="2"
                                IsVisible="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemRoleScopeTags.Count}">
                        <TextBlock Text="Role Scope Tags" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding $parent[ScrollViewer].((vm:MainWindowViewModel)DataContext).SelectedItemRoleScopeTags, Converter={x:Static conv:StringListConverter.Instance}}" FontSize="{StaticResource FontSizeBody}" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Section: Security Details -->
            <TextBlock Text="Security Details" Classes="SectionHeader"
                       IsVisible="{Binding SelectedItemTemplateDisplayName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <Border Classes="SectionCard"
                    IsVisible="{Binding SelectedItemTemplateDisplayName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Template Display Name" FontSize="{StaticResource FontSizeCaption}" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        <SelectableTextBlock Text="{Binding SelectedItemTemplateDisplayName}" FontSize="{StaticResource FontSizeBody}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Section: Assignments -->
            <controls:AssignmentListControl Assignments="{Binding SelectedItemAssignments}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
