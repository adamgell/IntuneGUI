{
  "$schema": "https://www.masterpackager.com/support-master-packager-dev/mpdev-schema.json",
  "outputTypes": [ "msi", "msix" ],
  "outputDirectory": "publish\\installer",
  "outputFileName": "IntuneCommander-$.version-x64",
  "packageName": "Intune Commander",
  "publisher": "Adam Gell",
  "version": "0.0.0.0",
  "platform": "x64",
  "installDir": "%ProgramFiles%\\Intune Commander",
  "icon": "icon.ico",
  "fileSystemEntries": [
    {
      "sourcePath": "%IC_DESKTOP_PUBLISH_DIR%",
      "targetPath": "$.installDir"
    },
    {
      "sourcePath": "%IC_CLI_PUBLISH_DIR%\\ic.exe",
      "targetPath": "$.installDir\\ic.exe"
    }
  ],
  "shortcuts": [
    {
      "target": "$.installDir\\IntuneCommander.exe",
      "name": "Intune Commander"
    }
  ],
  "environmentVariables": [
    {
      "name": "PATH",
      "value": "$.installDir"
    }
  ],
  "msi": {
    "upgradeCode": "{29E042C7-F159-466C-9F23-D2695288319A}",
    "installDialog": {
      "packageDescription": "Intune configuration manager for Commercial, GCC, GCC-High, and DoD clouds.",
      "publisherUrl": "https://github.com/adamgell/IntuneCommander",
      "eulaUrl": "https://github.com/adamgell/IntuneCommander/blob/main/LICENSE",
      "promptAppsAfterInstall": true
    }
  },
  "msix": {
    "publisher": "CN=Adam Gell"
  }
}
